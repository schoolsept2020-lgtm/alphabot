export const SCANNER_SYSTEM_PROMPT = `You are an elite crypto intelligence analyst. Identify coins with 50x-100x potential. Scan CEXs (Binance, Bybit, OKX), DEXs (Raydium, Pump.fun, Uniswap), whale wallets, and launchpads. Return ONLY a valid JSON array. No markdown. No explanation.

Format:
[
  {
    "symbol": "TOKEN",
    "name": "Full Token Name",
    "price": "$0.0XX",
    "priceChange24h": "+XX%",
    "marketCap": "$XXM",
    "narrative": "AI / Meme / RWA / GameFi / DePIN",
    "source": "Pump.fun / Raydium / Binance etc",
    "chain": "Solana / ETH / BNB / Base",
    "potentialMultiple": "50x-100x",
    "whyNow": "One sentence catalyst right now",
    "riskLevel": "High / Very High / Extreme",
    "signals": ["whale accumulation", "volume spike"],
    "entryNote": "Brief entry advice",
    "score": 85,
    "dexUrl": ""
  }
]

Rules: Return 6-10 coins. Score 0-100. Include 1 meme, 1 AI, 1 new chain coin minimum.`;

export async function runCryptoScan() {
  const Anthropic = (await import("@anthropic-ai/sdk")).default;
  const client = new Anthropic({ apiKey: process.env.ANTHROPIC_API_KEY });

  const message = await client.messages.create({
    model: "claude-sonnet-4-20250514",
    max_tokens: 4000,
    system: SCANNER_SYSTEM_PROMPT,
    tools: [{ type: "web_search_20250305", name: "web_search" }],
    messages: [{
      role: "user",
      content: `Run a FULL crypto market scan. Current UTC time: ${new Date().toUTCString()}.
Search for:
1. New listings on Binance, Bybit, OKX last 24-48h
2. Top trending on Pump.fun and Raydium right now
3. Whale accumulation on Ethereum and Solana
4. Coins with 10x+ volume spikes on any DEX today
5. Viral meme coins gaining traction on Crypto Twitter
6. New AI tokens launched in past 7 days
7. RWA or DePIN tokens with smart money inflow
Return ONLY a valid JSON array. No markdown. No explanation.`
    }]
  });

  let rawText = "";
  for (const block of message.content) {
    if (block.type === "text") rawText += block.text;
  }

  const jsonMatch = rawText.match(/\[[\s\S]*\]/);
  if (!jsonMatch) throw new Error("No JSON found in response");

  const coins = JSON.parse(jsonMatch[0]);
  if (!Array.isArray(coins) || coins.length === 0) throw new Error("Empty coin list");

  return coins;
}

export function formatTelegramMessage(coins, scanNumber) {
  const timestamp = new Date().toLocaleString("en-IN", { timeZone: "Asia/Kolkata" });
  const topCoins = coins.slice(0, 6);

  let msg = `⚡ *ALPHABOT SCAN #${scanNumber}*\n`;
  msg += `🕐 ${timestamp} IST\n`;
  msg += `📊 ${coins.length} coins surfaced\n`;
  msg += `——————————————\n\n`;

  topCoins.forEach((coin, i) => {
    const riskEmoji = coin.riskLevel === "High" ? "🟡" : coin.riskLevel === "Very High" ? "🟠" : "🔴";
    msg += `*${i + 1}. ${coin.symbol}* — Score: ${coin.score}/100\n`;
    msg += `💰 ${coin.price} (${coin.priceChange24h})\n`;
    msg += `📌 ${coin.narrative} · ${coin.chain}\n`;
    msg += `🏦 MCap: ${coin.marketCap} · ${coin.potentialMultiple}\n`;
    msg += `⚡ _${coin.whyNow}_\n`;
    msg += `${riskEmoji} Risk: ${coin.riskLevel}\n`;
    if (coin.dexUrl) msg += `🔗 [Chart](${coin.dexUrl})\n`;
    msg += `\n`;
  });

  msg += `——————————————\n`;
  msg += `_⚠️ DYOR. Not financial advice._`;
  return msg;
}

export async function sendTelegramMessage(text) {
  const token = process.env.TELEGRAM_BOT_TOKEN;
  const chatId = process.env.TELEGRAM_CHAT_ID;
  if (!token || !chatId) throw new Error("Telegram credentials missing");

  const res = await fetch(`https://api.telegram.org/bot${token}/sendMessage`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      chat_id: chatId,
      text,
      parse_mode: "Markdown",
      disable_web_page_preview: false
    })
  });

  if (!res.ok) throw new Error(`Telegram error: ${await res.text()}`);
  return res.json();
}
